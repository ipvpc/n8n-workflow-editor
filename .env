# App
N8N_WORKFLOW_EDITOR_PORT=8105
N8N_WORKFLOW_EDITOR_LOG_LEVEL=INFO
N8N_WORKFLOW_EDITOR_DATA_DIR=/data

# Database
POSTGRES_PASSWORD=n8n_editor

# n8n Connection
N8N_BASE_URL=
N8N_API_KEY=
N8N_HTTP_TIMEOUT_SECONDS=60
N8N_SKIP_TLS_VERIFY=false

# Azure OpenAI (optional)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure AI (optional)
AZURE_AI_ENDPOINT=
AZURE_AI_API_KEY=
AZURE_AI_DEPLOYMENT=

# OpenAI / compatible (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# AI tuning
N8N_EDITOR_AI_TEMPERATURE=0.2
N8N_EDITOR_AI_MAX_TOKENS=4096
